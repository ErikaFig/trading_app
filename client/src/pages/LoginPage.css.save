/* ===========================
   CONTENEDOR PRINCIPAL
=========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#eef3fa;
    font-family:Arial, Helvetica, sans-serif;
}

.login-container{

    min-height:100vh;

    display:flex;

    justify-content:center;

    align-items:center;

    padding:30px;

    background:#eef3fa;

}

/* ===========================
   TARJETA
=========================== */

.login-card{

    width:100%;

    max-width:900px;

    min-height:700px;

    background:white;

    display:flex;

    border-radius:24px;

    overflow:hidden;

    box-shadow:0 15px 40px rgba(0,0,0,.12);

}

/* ===========================
   PANEL IZQUIERDO
=========================== */

.left-panel{

    width:35%;

    background:linear-gradient(180deg,#081120,#122948);

    color:white;

    display:flex;

    flex-direction:column;

    justify-content:center;

    align-items:center;

    padding:50px;

    text-align:center;

}

.left-panel h1{

    font-size:54px;

    margin-bottom:20px;

}

.left-panel p{

    font-size:26px;

    color:#d7dce4;

    line-height:1.5;

}

.bull-box{

    margin-top:45px;

    font-size:90px;

}

/* ===========================
   PANEL DERECHO
=========================== */

.right-panel{

    width:55%;

    display:flex;

    flex-direction:column;

    justify-content:center;

    padding:60px;

}

.right-panel h2{

    font-size:56px;

    margin-bottom:10px;

}

.right-panel p{

    font-size:20px;

    color:#6b7280;

    margin-bottom:35px;

}

/* ===========================
   INPUTS
=========================== */

.input-group{

    display:flex;

    flex-direction:column;

    margin-bottom:24px;

}

.input-group label{

    margin-bottom:8px;

    font-size:22px;

    font-weight:bold;

}

.input-group input{

    width:100%;

    height:56px;

    border-radius:12px;

    border:1px solid #D1D5DB;

    padding:0 18px;

    font-size:17px;

}

/* ===========================
   BOTÓN
=========================== */

.main-button{

    width:100%;

    height:56px;

    border:none;

    border-radius:14px;

    background:#22C55E;

    color:white;

    font-size:20px;

    font-weight:bold;

    cursor:pointer;

    transition:.3s;

}

.main-button:hover{

    background:#16A34A;

}

/* ===========================
   LINKS
=========================== */

.right-panel a{

    color:#4F46E5;

    text-decoration:none;

    font-weight:bold;

}

.right-panel a:hover{

    text-decoration:underline;

}

/* ===================================================
                TABLETS
=================================================== */

@media(max-width:992px){

.login-card{

    max-width:900px;

}

.left-panel{

    padding:35px;

}

.left-panel h1{

    font-size:48px;

}

.left-panel p{

    font-size:22px;

}

.right-panel{

    padding:40px;

}

.right-panel h2{

    font-size:42px;

}

}

/* ===================================================
                CELULARES
=================================================== */

@media(max-width:768px){

.login-container{

    padding:15px;

}

.login-card{

    flex-direction:column;

    min-height:auto;

}

.left-panel{

    width:100%;

    padding:35px 20px;

}

.left-panel h1{

    font-size:42px;

}

.left-panel p{

    font-size:20px;

}

.bull-box{

    font-size:70px;

    margin-top:20px;

}

.right-panel{

    width:100%;

    padding:35px 25px;

}

.right-panel h2{

    font-size:40px;

}

.right-panel p{

    font-size:18px;

}

.input-group label{

    font-size:18px;

}

.input-group input{

    height:50px;

    font-size:16px;

}

.main-button{

    height:52px;

    font-size:18px;

}

}

/* ===================================================
          CELULARES PEQUEÑOS
=================================================== */

@media(max-width:480px){

.login-container{

    padding:0;

}

.login-card{

    border-radius:0;

    min-height:100vh;

    box-shadow:none;

}

.left-panel{

    padding:30px 15px;

}

.left-panel h1{

    font-size:34px;

}

.left-panel p{

    font-size:17px;

}

.bull-box{

    font-size:60px;

}

.right-panel{

    padding:30px 20px 40px;

}

.right-panel h2{

    font-size:34px;

}

.right-panel p{

    font-size:17px;

}

.input-group{

    margin-bottom:18px;

}

.input-group label{

    font-size:16px;

}

.input-group input{

    height:48px;

    font-size:15px;

}

.main-button{

    height:50px;

    font-size:17px;

}

}
